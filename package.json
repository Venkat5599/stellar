{
  "name": "veil",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Veil — private payments for autonomous agents on Stellar: a scoped session key (autonomy without custody) settling through a ZK shielded pool (stealth notes + Soroban Groth16/BN254).",
  "scripts": {
    "circuit:withdraw": "circom circuits/veil_withdraw.circom --r1cs --wasm --sym -l node_modules -o circuits/build",
    "circuit:insert": "circom circuits/veil_insert.circom --r1cs --wasm --sym -l node_modules -o circuits/build",
    "flow": "bun run scripts/veil-flow.ts",
    "agent:fabric": "bun run scripts/agent-fabric.ts",
    "gen:insert": "bun run scripts/veil-gen-insert.ts",
    "convert": "bun run sdk/veil-convert.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.107.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@noble/curves": "^2.2.0",
    "@stellar/stellar-sdk": "^13.0.0",
    "circomlib": "^2.0.5",
    "circomlibjs": "^0.1.7",
    "express": "^5.2.1",
    "snarkjs": "^0.7.6",
    "zod": "^4.4.3"
  }
}
