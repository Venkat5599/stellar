{
  "name": "ledgerproof",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Confidential proof-of-solvency on Stellar (Soroban + Groth16 ZK).",
  "scripts": {
    "seed": "bun run scripts/seed-ledger.ts",
    "circuit:compile": "circom circuits/solvency.circom --r1cs --wasm --sym -l node_modules -o circuits/build",
    "circuit:info": "snarkjs r1cs info circuits/build/solvency.r1cs",
    "ptau:download": "bun run scripts/download-ptau.ts",
    "setup": "bun run scripts/setup-keys.ts",
    "prove": "bun run scripts/prove.ts",
    "verify": "snarkjs groth16 verify circuits/build/verification_key.json circuits/build/public.json circuits/build/proof.json"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^13.0.0",
    "circomlib": "^2.0.5",
    "circomlibjs": "^0.1.7",
    "snarkjs": "^0.7.6"
  }
}
